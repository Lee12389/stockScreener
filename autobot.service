[Unit]
Description=AutoBot FastAPI Service
After=network.target

[Service]
User=azureuser
Group=azureuser
WorkingDirectory=/opt/autoBot
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/autoBot/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
