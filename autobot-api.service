[Unit]
Description=AutoBot Internal FastAPI API Service
After=network.target

[Service]
User=azureuser
Group=azureuser
WorkingDirectory=/opt/autoBot
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/autoBot/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 1516
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
