# App
APP_NAME=Angel One AutoTrader
APP_ENV=dev
HOST=127.0.0.1
PORT=1516
PUBLIC_HOST=0.0.0.0
PUBLIC_PORT=5015
SECRET_KEY=change-me
INTERNAL_API_BASE_URL=http://127.0.0.1:1516
WEB_DIST_DIR=client/dist

# Trading safety
ALLOW_LIVE_TRADES=false
DEFAULT_MODE=paper
MAX_ORDER_QTY=5
MAX_DAILY_TRADES=15

# Strategy defaults
TOP_N=10
BUY_THRESHOLD=2.0
SELL_THRESHOLD=-2.0

# Angel One credentials
ANGEL_API_KEY=
ANGEL_CLIENT_CODE=
ANGEL_PIN=
ANGEL_TOTP_SECRET=

# Optional watchlist symbols used for fallback analysis
WATCHLIST=SBIN-EQ,RELIANCE-EQ,INFY-EQ,HDFCBANK-EQ,TCS-EQ

# Frontend clients (comma separated), use * for local development
CORS_ORIGINS=*
